# AI Note Backend environment example.
# Copy this file to .env and fill in real values for local or server runtime.

# Security. Required. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-CHANGE-ME

# Comma-separated frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# App metadata.
APP_NAME=AI Note API
APP_VERSION=1.0.0
DEBUG=True
TIMEZONE=Asia/Shanghai

# Database. The default matches docker-compose.dev.yml.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_note_app

# Keep uploaded files outside the backend source tree.
UPLOAD_DIR=../runtime/uploaded_images

# Optional NexoraDB vector service for note-aware chat/RAG.
# NEXORADB_URL=http://chat.himpqblog.cn:9951
# NEXORADB_API_KEY=your-nexoradb-api-key
# CHAT_RAG_TOP_K=8
# CHAT_RAG_MAX_CHUNKS=6
# CHAT_RAG_MAX_NOTES=4
# CHAT_RAG_MAX_CONTEXT_CHARS=12000
# CHAT_HISTORY_CONTEXT_MESSAGES=12
# CHAT_STREAM_HEARTBEAT_SECONDS=12

# Optional SMTP settings for email verification.
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=True
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_NAME=AI Note

# Optional Doubao/Ark AI settings.
# Use either API key auth or AK/SK auth.
# DOUBAO_API_KEY=your-doubao-api-key-here
# DOUBAO_ACCESS_KEY_ID=your-access-key-id
# DOUBAO_SECRET_ACCESS_KEY=your-secret-access-key

# Doubao model settings.
# DOUBAO_MODEL_ID=doubao-seed-1-6-vision-250815
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_DETAIL=high
# DOUBAO_MAX_COMPLETION_TOKENS=6000
# DOUBAO_USE_JSON_SCHEMA=True

# Prompt/profile admin settings.
# PROMPT_PROFILES_PATH=app/prompts/profiles.json
# ADMIN_PORTAL_API_KEY=your-admin-api-key-here
